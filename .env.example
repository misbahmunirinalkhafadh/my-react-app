# Environment Variables Template
# Copy this file ke .env dan sesuaikan dengan local setup Anda
# 
# Note: Di React Vite, variabel harus diawali dengan VITE_ untuk expose ke client
# Contoh: VITE_API_URL, VITE_APP_NAME, dll

# ============================================
# Application Settings
# ============================================
VITE_APP_NAME=my-react-app
VITE_APP_VERSION=0.0.0

# ============================================
# API Configuration
# ============================================
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# ============================================
# Environment
# ============================================
VITE_ENV=development

# ============================================
# Feature Flags
# ============================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# ============================================
# Staging Environment (untuk deploy ke staging)
# ============================================
# VITE_API_URL_STAGING=https://staging-api.example.com/api
# STAGING_HOST=staging.example.com
# STAGING_USER=deploy
# STAGING_KEY=path/to/private/key

# ============================================
# Production Environment (untuk deploy ke production)
# ============================================
# VITE_API_URL_PROD=https://api.example.com/api
# PROD_HOST=example.com
# PROD_USER=deploy
# PROD_KEY=path/to/private/key
